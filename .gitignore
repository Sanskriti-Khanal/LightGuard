# ── LightGuard data / model exclusions ───────────────────────────────────────
# Rule 1: DATA NEVER ENTERS GIT.
data/raw/
data/processed/
data/external/
models/

# data/sample/ and reports/ ARE committed — do not add them here.

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb~

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
